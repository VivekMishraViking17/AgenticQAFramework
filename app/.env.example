# Server
HOST=0.0.0.0
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080

# Authentication
AUTH_ENABLED=false

# Auth mode: microsoft | access_code
#   microsoft   — Sign in with Microsoft (needs Entra app registration)
#   access_code — VikingCloud email + shared team code (no IT setup)
AUTH_MODE=access_code

# --- Option A: Team access code (fastest, no Azure needed) ---
ACCESS_CODE=change-me-to-a-strong-team-password

# --- Option B: Microsoft Entra ID ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

ALLOWED_EMAIL_DOMAINS=vikingcloud.com
SESSION_SECRET=
SESSION_HOURS=8
