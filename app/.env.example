# Server
HOST=0.0.0.0
PORT=8080

# Public URL users open in browser (required when AUTH_ENABLED=true)
# Local LAN example: http://192.168.1.50:8080
# Production example: https://qe.vikingcloud.com
PUBLIC_BASE_URL=http://localhost:8080

# Authentication — set true for VikingCloud user access
AUTH_ENABLED=false

# Microsoft Entra ID (Azure AD) — register app at https://entra.microsoft.com
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Allowed email domains (comma-separated)
ALLOWED_EMAIL_DOMAINS=vikingcloud.com

# Session signing secret — generate: openssl rand -hex 32
SESSION_SECRET=
SESSION_HOURS=8
